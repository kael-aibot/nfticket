# -----------------------------------------------------------------------------
# NFTicket environment template
# Copy this file to `.env.local` or `.env` and replace placeholder values.
# Each entry is marked as:
#   - Required: needed for the related feature to work
#   - Optional: safe to leave unset unless you enable that feature
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------

# Required: runtime mode used by Next.js and shared server utilities.
NODE_ENV=development

# Optional: deployment environment label used by app config parsing.
APP_ENV=development

# Required when generating absolute URLs for auth and payment redirects.
# Expected format: full origin, no trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Optional: app release identifier for server-side observability.
# Expected format: semver, git SHA, or deployment version.
APP_VERSION=dev

# Optional: app release identifier exposed to the browser for client-side observability.
# Expected format: semver, git SHA, or deployment version.
NEXT_PUBLIC_APP_VERSION=dev

# Optional: selects the runtime storage backend.
# Allowed values: browser, memory, prisma
PERSISTENCE_DRIVER=browser

# -----------------------------------------------------------------------------
# Auth and session security
# -----------------------------------------------------------------------------

# Required: HMAC secret used to sign and verify server session tokens.
# Expected format: long random string, at least 32 characters.
SESSION_SECRET=replace-with-a-32-plus-character-random-session-secret

# Optional: reserved compatibility secret for JWT-based auth integrations.
# Expected format: long random string, at least 32 characters.
JWT_SECRET=replace-with-a-32-plus-character-random-jwt-secret

# Optional: reserved compatibility key for encrypting sensitive values at rest.
# Expected format: 32-byte key encoded as hex or base64, depending on your implementation.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional: legacy/demo auth mode setting used by parts of the frontend.
# Allowed values seen in the codebase: email, wallet
AUTH_MODE=email

# Optional: public auth mode override used by shared hooks in the browser.
# Allowed values seen in the codebase: email, wallet
NEXT_PUBLIC_NFTICKET_AUTH_MODE=email

# Optional: NextAuth compatibility settings kept for integrations and future auth work.
NEXTAUTH_URL=http://localhost:3002

# Optional: NextAuth signing secret if NextAuth is enabled.
# Expected format: long random string, at least 32 characters.
NEXTAUTH_SECRET=replace-with-a-32-plus-character-random-nextauth-secret

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------

# Optional: sender address for email-based auth or notifications.
EMAIL_FROM=no-reply@nfticket.local

# Optional: SMTP host for local or production email delivery.
SMTP_HOST=localhost

# Optional: SMTP port number.
SMTP_PORT=1025

# Optional: SMTP username if your provider requires authentication.
SMTP_USER=

# Optional: SMTP password if your provider requires authentication.
SMTP_PASSWORD=

# Optional: set to true when your SMTP server requires implicit TLS.
# Allowed values: true, false
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------

# Optional: Stripe secret key for server-side checkout creation.
# Required if `PAYMENTS_ENABLE_STRIPE=true`.
# Expected format: sk_test_... or sk_live_...
STRIPE_SECRET_KEY=sk_test_replace_me

# Optional: Stripe webhook signing secret for webhook verification.
# Required if Stripe webhooks are enabled.
# Expected format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: Stripe publishable key exposed to the browser.
# Required if `PAYMENTS_ENABLE_STRIPE=true`.
# Expected format: pk_test_... or pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Optional: Stripe Connect platform account for destination charges / transfers.
# Expected format: acct_...
STRIPE_CONNECT_PLATFORM_ACCOUNT=acct_replace_me

# Optional: enables Stripe as a payment rail.
# Allowed values: true, false
PAYMENTS_ENABLE_STRIPE=true

# Optional: enables native SOL checkout flows.
# Allowed values: true, false
PAYMENTS_ENABLE_SOL=true

# Optional: enables USDC checkout flows on Solana.
# Allowed values: true, false
PAYMENTS_ENABLE_USDC=true

# -----------------------------------------------------------------------------
# Blockchain / Solana
# -----------------------------------------------------------------------------

# Required for blockchain-enabled flows: target Solana cluster.
# Allowed values: devnet, testnet, mainnet-beta, localnet
SOLANA_CLUSTER=devnet

# Required for blockchain-enabled flows: RPC endpoint used by backend services.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: public RPC endpoint exposed to browser wallet flows.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: Solana commitment level.
# Allowed values: processed, confirmed, finalized
SOLANA_COMMITMENT=confirmed

# Optional for demo-only flows, required for real minting / fulfillment.
# Expected format: JSON array of secret key bytes.
SOLANA_PAYER_SECRET=[12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78]

# Required for blockchain-enabled settlement flows.
# Expected format: Solana public key (base58).
SOLANA_TREASURY_WALLET=ReplaceWithTreasuryWalletPublicKey1111111111111111

# Required when USDC payments are enabled.
# Expected format: Solana mint public key (base58).
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Optional: default NFT issuance mode.
# Allowed values: compressed, metadata
NFT_DEFAULT_MODE=compressed

# Optional: public NFT issuance mode used by frontend hooks.
# Allowed values: compressed, metadata
NEXT_PUBLIC_NFTICKET_NFT_MODE=compressed

# Optional: fallback NFT image URI used during fulfillment.
# Expected format: absolute HTTPS URL.
NFTICKET_DEFAULT_IMAGE_URI=https://placehold.co/1200x630/png?text=NFTicket

# Optional for demo-only flows, required for compressed minting.
# Expected format: Solana public key (base58).
SOLANA_MERKLE_TREE_ADDRESS=ReplaceWithMerkleTreePublicKey111111111111111111

# Optional compatibility alias for `SOLANA_MERKLE_TREE_ADDRESS`.
# Expected format: Solana public key (base58).
SOLANA_MERKLE_TREE=ReplaceWithMerkleTreePublicKey111111111111111111

# Optional for demo-only flows, required for collection-backed minting.
# Expected format: Solana public key (base58).
SOLANA_COLLECTION_MINT=ReplaceWithCollectionMintPublicKey11111111111111111

# Optional for demo-only flows, required when collection verification is enforced.
# Expected format: Solana public key (base58).
SOLANA_COLLECTION_UPDATE_AUTHORITY=ReplaceWithCollectionUpdateAuthority1111111111

# Optional compatibility alias for `SOLANA_COLLECTION_UPDATE_AUTHORITY`.
# Expected format: Solana public key (base58).
SOLANA_COLLECTION_AUTHORITY=ReplaceWithCollectionUpdateAuthority1111111111

# -----------------------------------------------------------------------------
# Scanner / provider security
# -----------------------------------------------------------------------------

# Required for scanner login and device-bound scanner token signing.
# Expected format: long random string, at least 32 characters.
SCANNER_JWT_SECRET=replace-with-a-32-plus-character-random-scanner-secret

# Required for stable device fingerprint hashing in scanner auth.
# Expected format: long random string, at least 32 characters.
DEVICE_ID_SALT=replace-with-a-32-plus-character-random-device-salt

# -----------------------------------------------------------------------------
# Database and storage
# -----------------------------------------------------------------------------

# Optional for the current demo runtime, required when Prisma persistence is enabled.
# Expected format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nfticket

# Optional: Redis connection string for future caching / jobs / coordination layers.
# Expected format: redis://host:port
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Optional: server-side Sentry DSN.
# Expected format: https://<key>@<host>/<project>
SENTRY_DSN=

# Optional: browser-exposed Sentry DSN.
# Expected format: https://<key>@<host>/<project>
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# KYC
# -----------------------------------------------------------------------------

# Optional: enables KYC gating logic.
# Allowed values: true, false
KYC_ENABLED=false

# Optional: KYC provider identifier.
KYC_PROVIDER=

# Optional: API key for the configured KYC provider.
KYC_API_KEY=

# Optional: webhook secret for KYC provider callbacks.
KYC_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------

# Optional: enables canonical domain and repository-layer usage.
# Allowed values: true, false
FF_ENABLE_CORE_DOMAIN=true

# Optional: enables normalized event configuration reads and writes.
# Allowed values: true, false
FF_ENABLE_NORMALIZED_EVENT_CONFIG=true

# Optional: enables background job scheduling code paths.
# Allowed values: true, false
FF_ENABLE_BACKGROUND_JOBS=false

# Optional: enables Prisma-backed persistence code paths.
# Allowed values: true, false
FF_ENABLE_PRISMA_PERSISTENCE=false

# Optional: enables chain indexing services.
# Allowed values: true, false
FF_ENABLE_CHAIN_INDEXER=false

# -----------------------------------------------------------------------------
# Marketplace / resale defaults
# -----------------------------------------------------------------------------

# Optional: maximum resale markup percentage.
RESALE_MAX_MARKUP_PERCENT=20

# Optional: royalty percentage retained on resale.
RESALE_ROYALTY_PERCENT=10

# Optional: transfer window duration after purchase, in hours.
RESALE_TRANSFER_WINDOW_HOURS=24
